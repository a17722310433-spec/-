<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6DC96">

    <!-- ====== 顶部栏 ====== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="#795548"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="8dp">

        <Button
            android:id="@+id/network_button"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:text="联机"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="五子棋"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/settings_button"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:text="⚙"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- ====== 状态文字 ====== -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="1dp"
        android:text="轮到你：黑棋"
        android:textColor="#3E2723"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/stats_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="3dp"
        android:text="胜 0  负 0  平 0"
        android:textColor="#8D6E63"
        android:textSize="12sp" />

    <!-- ====== 棋盘 ====== -->
    <com.wuziqi.gomoku.GomokuView
        android:id="@+id/gomoku_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ====== 控制面板（2行共7按钮） ====== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_control_panel"
        android:orientation="vertical"
        android:padding="5dp">

        <!-- 行1：执黑 / 双人 / 难度 / 观战 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/color_toggle_button"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_selected"
                android:text="⚫ 执黑"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/pvp_button"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_normal"
                android:text="双人"
                android:textColor="#4A2C1A"
                android:textSize="13sp" />

            <Button
                android:id="@+id/level_button"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_normal"
                android:text="普通"
                android:textColor="#4A2C1A"
                android:textSize="13sp" />

            <Button
                android:id="@+id/watch_button"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_normal"
                android:text="观战"
                android:textColor="#4A2C1A"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 行2：重来 / 撤回 / 提示 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/restart_button"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_action"
                android:text="↺ 重来"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/undo_button"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_action"
                android:text="↩ 撤回"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/hint_button"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_action"
                android:text="💡 提示"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 回放（默认隐藏） -->
        <LinearLayout
            android:id="@+id/replay_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/replay_prev_button"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_action"
                android:text="◀ 上一步"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/replay_next_button"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_action"
                android:text="下一步 ▶"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/replay_exit_button"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_margin="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_normal"
                android:text="✕ 退出"
                android:textColor="#4A2C1A"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
